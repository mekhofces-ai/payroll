# Application
APP_NAME="IPTV Subscription Manager"
APP_VERSION="1.0.0"
DEBUG=true
SECRET_KEY="your-super-secret-key-change-in-production-min-32-chars"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
# SQLite (default for development)
DATABASE_URL="sqlite+aiosqlite:///./iptv_manager.db"
# PostgreSQL (for production)
# DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/iptv_manager"

# Encryption
ENCRYPTION_KEY="your-32-byte-base64-encoded-encryption-key-here"

# Server
HOST="0.0.0.0"
PORT=8000

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Logging
LOG_LEVEL="INFO"
LOG_FORMAT="json"

# Email Notifications (optional)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""
SMTP_TLS=true

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Discord Notifications (optional)
DISCORD_WEBHOOK_URL=""

# Scheduler
SCHEDULER_ENABLED=true
STATUS_CHECK_INTERVAL_HOURSAL_HOURS=6
EXPIRY_WARNING_DAYS=7

# CORS
ALLOWED_ORIGINS="http://localhost:8000,http://127.0.0.1:8000"

# Proxy (optional)
DEFAULT_PROXY_URL=""